{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,

  "provider": {
    "amazon-bedrock": {},
    "vertex": {},
    "openrouter": {}
  },

  "agent": {
    "plan": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1",
			"variant": "high"
    },
    "build": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6-v1"
    }
  },

  "permission": {
    "bash": "allow",
    "edit": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "read": "allow",
    "webfetch": "allow",
    "write": "allow"
  },

  "permission": {
    "external_directory": {
      "~/.config/opencode/**": "allow"
    }
  },

  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    }
  }
}
